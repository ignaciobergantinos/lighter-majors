#!/usr/bin/env bash
#
# lighter — start the Lighter Majors trading widget
#
# Usage:
#   lighter          # production mode (builds first if needed)
#   lighter dev      # development mode with hot-reload
#   lighter build    # build only, don't start
#   lighter stop     # stop the background server
#

set -euo pipefail

SCRIPT="$0"
# Resolve symlinks so we always find the real project directory
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  # Handle relative symlinks
  [[ "$SCRIPT" != /* ]] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
PROJECT_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
PID_FILE="$PROJECT_DIR/.lighter.pid"
LOG_FILE="$PROJECT_DIR/.lighter.log"
PORT="${LIGHTER_PORT:-3000}"

cd "$PROJECT_DIR"

case "${1:-start}" in
  dev)
    echo "🔥 Starting lighter in dev mode on http://localhost:$PORT"
    exec npx next dev --port "$PORT"
    ;;

  build)
    echo "📦 Building lighter..."
    npx next build
    echo "✅ Build complete"
    ;;

  stop)
    if [ -f "$PID_FILE" ]; then
      PID=$(cat "$PID_FILE")
      if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        rm -f "$PID_FILE"
        echo "🛑 Lighter stopped (PID $PID)"
      else
        rm -f "$PID_FILE"
        echo "⚠️  No running process found, cleaned up stale PID file"
      fi
    else
      echo "⚠️  Lighter is not running"
    fi
    ;;

  start)
    echo "🖥️  Starting Lighter Majors desktop app..."
    exec npm run desktop
    ;;

  status)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      echo "✅ Lighter is running (PID $(cat "$PID_FILE")) on http://localhost:$PORT"
    else
      echo "⚠️  Lighter is not running"
    fi
    ;;

  autostart-on)
    PLIST="$PROJECT_DIR/com.lighter-majors.plist"
    cp "$PLIST" ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.lighter-majors.plist 2>/dev/null || true
    echo "✅ Lighter will auto-start on login"
    echo "   To disable: lighter autostart-off"
    ;;

  autostart-off)
    launchctl unload ~/Library/LaunchAgents/com.lighter-majors.plist 2>/dev/null || true
    rm -f ~/Library/LaunchAgents/com.lighter-majors.plist
    echo "🛑 Auto-start disabled"
    ;;

  *)
    echo "Usage: lighter [dev|build|start|stop|status|autostart-on|autostart-off]"
    echo ""
    echo "Commands:"
    echo "  start            Start production server (default)"
    echo "  start --daemon   Start in background"
    echo "  dev              Start dev server with hot-reload"
    echo "  build            Build for production"
    echo "  stop             Stop background server"
    echo "  status           Check if server is running"
    echo "  autostart-on     Enable auto-start on macOS login"
    echo "  autostart-off    Disable auto-start on macOS login"
    exit 1
    ;;
esac
