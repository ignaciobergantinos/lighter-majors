{
  "name": "lighter-scaffold",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "lighter": "./bin/lighter"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop": "node scripts/desktop-dev.js",
    "desktop:build": "tsc --project electron/tsconfig.json",
    "desktop:package": "npm run build && npm run desktop:build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "zklighter-sdk": "^1.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.lighter-majors.desktop",
    "productName": "Lighter Majors",
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
