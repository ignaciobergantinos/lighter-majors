# Lighter Exchange Configuration
# Copy this to .env.local and fill in your values

# Your Lighter account index (required for trading)
LIGHTER_ACCOUNT_INDEX=0

# Auth token generated via Lighter SDK (required for trading)
# Format: {expiry_unix}:{account_index}:{api_key_index}:{random_hex}
LIGHTER_AUTH_TOKEN=

# API endpoints (defaults to mainnet — uncomment for testnet)
# NEXT_PUBLIC_LIGHTER_API_URL=https://testnet.zklighter.elliot.ai
# NEXT_PUBLIC_LIGHTER_WS_URL=wss://testnet.zklighter.elliot.ai/stream
# NEXT_PUBLIC_LIGHTER_EXPLORER_URL=https://explorer.elliot.ai/api
