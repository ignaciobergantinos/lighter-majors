# Lighter Exchange Configuration
# Copy this to .env.local and fill in your values

# ── API Key Triplet (required for trading) ──────────────────
# Lighter provides keys as a triplet: index + public key + private key.
# Generate via: npx zklighter-sdk key (or the Lighter dashboard)
LIGHTER_API_KEY_INDEX=0
LIGHTER_PUBLIC_KEY=
LIGHTER_PRIVATE_KEY=

# Your Lighter account index
LIGHTER_ACCOUNT_INDEX=0

# ── Discord Notifications (optional) ──────────────────────
# Webhook URL for trade event notifications (open/close)
# Create one at: Discord Server Settings → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── API Endpoints (defaults to mainnet) ─────────────────────
# Uncomment for testnet:
# NEXT_PUBLIC_LIGHTER_API_URL=https://testnet.zklighter.elliot.ai
# NEXT_PUBLIC_LIGHTER_WS_URL=wss://testnet.zklighter.elliot.ai/stream
# NEXT_PUBLIC_LIGHTER_EXPLORER_URL=https://explorer.elliot.ai/api
